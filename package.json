{
  "name": "playwright-ai-studio",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright runner for goldens produced by the AI Studio backend.",
  "scripts": {
    "test": "playwright test",
    "test:ci": "playwright test --reporter=list,html,json,junit",
