# ── Secrets ───────────────────────────────────────────────────────────────────
# NEVER commit real credentials. `.env.example` is the template that stays.
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Node / Playwright ─────────────────────────────────────────────────────────
node_modules/
.npm/
.pnpm-store/

# Generated by ci/export_goldens.py — re-created on every pipeline run
tests/

# Playwright outputs
playwright-report/
test-results/
results.json
junit.xml
.last-run.json
blob-report/
.cache/

# ── Studio runtime data ───────────────────────────────────────────────────────
# goldens/ is committed (source of truth for tests).
# Logs, runs, auth sessions, explorations, and test-results are runtime artifacts — never commit them.
runs/
studio/runs/
studio/logs/
studio/.auth/
studio/explorations/

# Playwright MCP transient artifacts — YAML snapshots + console logs written per session
studio/.playwright-mcp/

# Learned knowledge files — intentionally NOT ignored; commit these
# (selector_memory.json, exploration_patterns.json, learned_rules.json accumulate real value)

# ── Editors / OS ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
.DS_Store?
Thumbs.db
__pycache__/
*.pyc

# ── Build artifacts ───────────────────────────────────────────────────────────
dist/
build/
*.log
