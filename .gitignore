# ── Secrets ───────────────────────────────────────────────────────────────────
# NEVER commit real credentials. `.env.example` is the template that stays.
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Node / Playwright ─────────────────────────────────────────────────────────
node_modules/
.npm/
.pnpm-store/

# Generated by ci/export_goldens.py — re-created on every pipeline run
tests/

# Playwright outputs
playwright-report/
test-results/
results.json
junit.xml
.last-run.json
blob-report/
.cache/

# ── Studio runtime data ───────────────────────────────────────────────────────
# Uncomment the next two lines if you DO NOT want to commit goldens / run history.
# Most teams DO commit goldens (they're the source of truth for tests) and
# leave runs/ out of git.
# golden/
runs/

# ── Editors / OS ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Build artifacts ───────────────────────────────────────────────────────────
dist/
build/
*.log
