# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# For synthesize and auto-heal features
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o          # your deployed model name in Azure

# ── GitHub CI Integration ──────────────────────────────────────────────────────
# For triggering GitHub Actions workflows from the Studio UI
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repository-name
GITHUB_WORKFLOW=playwright-test.yml     # workflow filename in .github/workflows/
GITHUB_BRANCH=main                      # branch to trigger workflow on

# ── App credentials (for login-required test targets) ────────────────────────
# Add one block per application. Tests never read these directly —
# the auth script logs in once and saves a storageState file instead.
#
# Example — SAP SuccessFactors:
# APP_SF_URL=https://your-tenant.successfactors.com
# APP_SF_USER=your.user@company.com
# APP_SF_PASS=your-password
#
# Example — any other app:
# APP_MYAPP_URL=https://app.example.com
# APP_MYAPP_USER=testuser
# APP_MYAPP_PASS=testpassword

# ── Git sync hardening (P2-2) ────────────────────────────────────────────────
# Set to "true" to disable the server's auto-push of saved goldens to GitHub.
# When disabled, goldens are written locally only — you commit + push manually.
# Useful when you're iterating fast and don't want every save to hit the remote.
# GIT_SYNC_DISABLED=true

# ── Vision policy (P2-3) ─────────────────────────────────────────────────────
# Controls which URLs the synthesis/healing vision pipeline is allowed to
# screenshot and send to Azure OpenAI.
#
# Format: comma-separated glob patterns matched against the URL's hostname
#   (case-insensitive; * works as a wildcard for one segment).
#
# Behaviour:
#   - UNSET (or empty) → allow ALL hosts (current default; backward compatible)
#   - "none"            → block ALL vision calls (text-only synthesis everywhere)
#   - any other value   → only listed patterns are allowed; everything else
#                         falls back to text-only synthesis with a log warning
#
# Examples:
#   VISION_ALLOWED_HOSTS=wikipedia.org,github.com,*.github.io,mdn.io,stackoverflow.com
#   VISION_ALLOWED_HOSTS=*.your-company.com,staging.your-company.com
#   VISION_ALLOWED_HOSTS=none      # vision disabled
#
# Recommendation:
#   - Solo laptop dev → leave unset (allow-all is fine).
#   - Shared host / multi-user deployment → set to your curated public list.
#   - Compliance-sensitive setup → set to "none" and run vision only locally.

# VISION_ALLOWED_HOSTS=

# ── App ───────────────────────────────────────────────────────────────────────
# PORT=8000  (optional — default is 8000)
